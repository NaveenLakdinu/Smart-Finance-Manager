<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fillViewport="true"
    android:overScrollMode="never">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <LinearLayout
            android:id="@+id/topCard"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="@drawable/top_gradient_card"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20% Complete"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Details"
                android:textColor="#374151"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Progress bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">

                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_active"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive" />
            </LinearLayout>
        </LinearLayout>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="120dp"
            android:outlineProvider="none"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="36dp">

                <!-- ── FULL NAME ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_person" android:layout_marginEnd="10dp"
                        android:contentDescription="person" />
                    <EditText android:id="@+id/etFullName" android:layout_width="match_parent" android:layout_height="match_parent"
                        android:hint="Username, Email &amp; Phone Number"
                        android:textColorHint="#9CA3AF" android:textColor="#111827"
                        android:textSize="14sp" android:background="@android:color/transparent"
                        android:inputType="textPersonName" />
                </LinearLayout>

                <!-- ── AGE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_cake" android:layout_marginEnd="10dp"
                        android:contentDescription="age" />
                    <EditText android:id="@+id/etAge" android:layout_width="match_parent" android:layout_height="match_parent"
                        android:hint="Enter your age" android:textColorHint="#9CA3AF"
                        android:textColor="#111827" android:textSize="14sp"
                        android:background="@android:color/transparent" android:inputType="number" />
                </LinearLayout>

                <!-- ── EMAIL ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_email" android:layout_marginEnd="10dp"
                        android:contentDescription="email" />
                    <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="match_parent"
                        android:hint="Enter your email" android:textColorHint="#9CA3AF"
                        android:textColor="#111827" android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:inputType="textEmailAddress" />
                </LinearLayout>

                <!-- ── MOBILE NUMBER ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Number"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="18dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_phone" android:layout_marginEnd="10dp"
                        android:contentDescription="phone" />
                    <EditText android:id="@+id/etMobile" android:layout_width="match_parent" android:layout_height="match_parent"
                        android:hint="Enter your mobile number" android:textColorHint="#9CA3AF"
                        android:textColor="#111827" android:textSize="14sp"
                        android:background="@android:color/transparent" android:inputType="phone" />
                </LinearLayout>

                <!-- ── PASSWORD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_field_bg"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="6dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_lock" android:layout_marginEnd="10dp"
                        android:contentDescription="lock" />
                    <EditText android:id="@+id/etPassword"
                        android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Create password" android:textColorHint="#9CA3AF"
                        android:textColor="#111827" android:textSize="14sp"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword" />
                    <ImageView android:id="@+id/passwordToggle"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:src="@drawable/ic_eye"
                        android:contentDescription="toggle password" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="At least 8 characters with letters and numbers"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="4dp" />



                <!-- ── CHECKBOX 1 — I have a loan ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:id="@+id/checkLoan"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:buttonTint="#22C55E"
                        android:checked="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I have a loan"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- ── CHECKBOX 2 — Terms and conditions ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:id="@+id/checkTerms"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:buttonTint="#22C55E"
                        android:checked="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I agree to the "
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/termsLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="terms and conditions"
                        android:textColor="#3B82F6"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ── CHECKBOX 3 — Subscription updates ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:id="@+id/checkSubscription"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:buttonTint="#22C55E"
                        android:checked="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I want to receive subscription updates"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- ── CHECKBOX 4 — Saving plan ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp">

                    <CheckBox
                        android:id="@+id/checkSaving"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:buttonTint="#22C55E"
                        android:checked="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I do have a saving plan"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- ── NEXT BUTTON ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Register"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_register_dark"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center"
                    android:layout_marginBottom="20dp"
                    app:backgroundTint="@null"
                    app:cornerRadius="30dp"
                    app:elevation="0dp" />

                <!-- Loading Indicator -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:indeterminateTint="#071A33"
                    android:layout_marginBottom="20dp" />

                <!-- ── LOGIN LINK ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Already have an account? " android:textColor="#6B7280"
                        android:textSize="14sp" />
                    <TextView android:id="@+id/loginLink"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Login" android:textColor="#3B82F6"
                        android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>
</ScrollView>