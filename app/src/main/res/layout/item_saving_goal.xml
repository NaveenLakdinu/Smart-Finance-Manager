<?xml version="1.0" encoding="utf-8"?>
<!-- item_saving_goal.xml: Detailed card for SavingListActivity -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/goal_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dashboard"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Title + Edit/Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvGoalName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Goal Name" />

            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✎"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="🗑"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="14sp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- Row 2: Target & Current -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Target: prefix in grey, value in grey -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target "
                android:textColor="@color/text_on_dark_primary"
                android:textSize="13sp"/>
            <TextView
                android:id="@+id/tvTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rs 0.00"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="13sp"/>

            <!-- Current: prefix in grey, value in mint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current "
                android:textColor="@color/text_on_dark_primary"
                android:textSize="13sp"/>
            <TextView
                android:id="@+id/tvCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs 0.00"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp"/>

        <!-- Progress bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/bg_progress_track">
            <View
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/goal_mint"/>
        </FrameLayout>

        <View android:layout_width="match_parent" android:layout_height="14dp"/>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Ongoing"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_ongoing"/>

        <!-- Keep dummy invisible views to prevent Java NPEs during transition if needed -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone">
            <TextView android:id="@+id/tvRemaining" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvPercent" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
