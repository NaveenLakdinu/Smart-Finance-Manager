<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/forest_900"
    tools:context=".StudentProfileFragment">

    <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
    <!--   SCROLLABLE CONTENT AREA                 -->
    <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/profileContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
            <!--   HERO HEADER: Avatar + Name + Stats      -->
            <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutProfileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_budget_header"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="32dp">

                <!-- Decorative circle accent top-right -->
                <View
                    android:id="@+id/viewProfileCircleAccent"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="-30dp"
                    android:alpha="0.12"
                    android:background="@drawable/bg_profile_circle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Avatar Circle -->
                <FrameLayout
                    android:id="@+id/frameProfileAvatar"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Outer white ring -->
                    <View
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_avatar_ring" />

                    <!-- Avatar background circle -->
                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_profile_circle">

                        <ImageView
                            android:id="@+id/imgProfileAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            android:contentDescription="Profile Avatar"
                            app:tint="@color/text_on_dark_primary" />

                    </FrameLayout>

                    <!-- Edit badge -->
                    <FrameLayout
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/icon_circle_secondary"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Γ£Å"
                            android:textSize="10sp"
                            android:textColor="@color/text_on_dark_primary" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Dulani Perera"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/frameProfileAvatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Email -->
                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="dulani@university.lk"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- University Info -->
                <TextView
                    android:id="@+id/txtProfileUniversity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="University of Colombo ΓÇó Year 4"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileEmail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ΓöÇΓöÇ Stats Row ΓöÇΓöÇ -->
                <LinearLayout
                    android:id="@+id/layoutProfileStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileUniversity"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Goals Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatGoals"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_stat_chip"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        tools:ignore="RtlHardcoded">

                        <!-- Corner radius via ShapeAppearance not available simply, using bg_notification shape fallback -->
                        <TextView
                            android:id="@+id/txtStatGoalsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Goals"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Saved Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatSaved"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_stat_chip"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatSavedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs.1.2L"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Saved"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Score Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatScore"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_chip"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatScoreValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Score"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
            <!--   CONTENT CARDS AREA                      -->
            <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
            <LinearLayout
                android:id="@+id/layoutProfileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp"
                android:layout_marginTop="-8dp">

                <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
                <!--   MY ACHIEVEMENTS CARD                    -->
                <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/forest_700"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
        app:strokeColor="@color/forest_600">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="≡ƒÅà"
                                android:textSize="20sp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/txtAchievementsTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Achievements"
                                android:textColor="@color/text_on_dark_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Badges Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- Badge 1: Goal Setter (pink/red) -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeGoalSetter"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/icon_role_red"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="≡ƒÄ»"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadgeGoalSetter"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Goal Setter"
                                    android:textColor="@color/danger_text"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                            <!-- Badge 2: 50% Saver (amber) -->
                            <LinearLayout
                                android:id="@+id/layoutBadge50Saver"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/icon_role_amber"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Γ¡É"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadge50Saver"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="50% Saver"
                                    android:textColor="@color/pill_warning_text"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                            <!-- Badge 3: Budget Pro (green) -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeBudgetPro"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/icon_role_green"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="≡ƒôè"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadgeBudgetPro"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Budget Pro"
                                    android:textColor="@color/forest_300"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
                <!--   SETTINGS MENU CARD                      -->
                <!-- ΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉΓòÉ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/forest_700"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
        app:strokeColor="@color/forest_600">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <!-- ΓöÇΓöÇ Menu Item 1: Account Settings ΓöÇΓöÇ -->
                        <LinearLayout
                            android:id="@+id/menuAccountSettings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <!-- Icon Circle -->
                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="14dp">

                                <View
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:background="@drawable/icon_circle_secondary" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    android:contentDescription="Account Settings"
                                    app:tint="@color/qa_secondary_icon" />

                            </FrameLayout>

                            <!-- Text -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtMenuAccountTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Account Settings"
                                    android:textColor="@color/text_on_dark_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtMenuAccountSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Profile, password"
                                    android:textColor="@color/text_on_dark_muted"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <!-- Chevron -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ΓÇ║"
                                android:textColor="@color/text_on_dark_muted"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/glass_card_bg"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp" />

                        <!-- ΓöÇΓöÇ Menu Item 2: Notifications ΓöÇΓöÇ -->
                        <LinearLayout
                            android:id="@+id/menuNotifications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="14dp">

                                <View
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:background="@drawable/icon_circle_orange" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_notification"
                                    android:contentDescription="Notifications"
                                    app:tint="@color/pill_warning_text" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtMenuNotifTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Notifications"
                                    android:textColor="@color/text_on_dark_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtMenuNotifSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Payment reminders"
                                    android:textColor="@color/text_on_dark_muted"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ΓÇ║"
                                android:textColor="@color/text_on_dark_muted"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/glass_card_bg"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp" />

                        <!-- ΓöÇΓöÇ Menu Item 3: Privacy & Security ΓöÇΓöÇ -->
                        <LinearLayout
                            android:id="@+id/menuPrivacySecurity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="14dp">

                                <View
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:background="@drawable/icon_circle_green" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_lock"
                                    android:contentDescription="Privacy and Security"
                                    app:tint="@color/forest_300" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtMenuPrivacyTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Privacy &amp; Security"
                                    android:textColor="@color/text_on_dark_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtMenuPrivacySubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="2FA, data security"
                                    android:textColor="@color/text_on_dark_muted"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ΓÇ║"
                                android:textColor="@color/text_on_dark_muted"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/glass_card_bg"
                            android:layout_marginStart="18dp"
                            android:layout_marginEnd="18dp" />

                        <!-- ΓöÇΓöÇ Menu Item 4: Help & Support ΓöÇΓöÇ -->
                        <LinearLayout
                            android:id="@+id/menuHelpSupport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="14dp">

                                <View
                                    android:layout_width="42dp"
                                    android:layout_height="42dp"
                                    android:background="@drawable/icon_circle_tertiary" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_info"
                                    android:contentDescription="Help and Support"
                                    app:tint="@color/forest_300" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtMenuHelpTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Help &amp; Support"
                                    android:textColor="@color/text_on_dark_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtMenuHelpSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="FAQs, contact us"
                                    android:textColor="@color/text_on_dark_muted"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ΓÇ║"
                                android:textColor="@color/text_on_dark_muted"
                                android:textSize="22sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ΓöÇΓöÇ App Version Info ΓöÇΓöÇ -->
                <LinearLayout
                    android:id="@+id/layoutVersionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtAppVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Finance v1.0.0"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtAppTagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Final Year Project ΓÇó 2026"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- ΓöÇΓöÇ Sign Out Button ΓöÇΓöÇ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnProfileLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/forest_700"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_power"
                            android:contentDescription="Sign Out"
                            app:tint="@color/danger_text" />

                        <TextView
                            android:id="@+id/txtSignOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="@color/danger_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
