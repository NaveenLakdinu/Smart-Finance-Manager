<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_role_upgrade.xml — Premium dark glassmorphic upgrade layout.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="36dp">

        <!-- ── Hero Header ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <!-- Top bar: back button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Back"
                    android:padding="9dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_on_dark_primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_accent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="ROLE UPGRADE"
                    android:textColor="@color/hero_accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Upgrade Title & Graphic -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Elevate Your Profile"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Transition from Student to Student-Worker Hybrid and unlock combined financial capabilities."
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="14sp" />

            <!-- Dynamic visual transition pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_glass_card"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓 Student"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_signup_arrow"
                    app:tint="@color/hero_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓💼 Hybrid"
                    android:textColor="@color/hero_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Main Content / Feature breakdown ──────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMBINED BENEFITS"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <!-- Student Functions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_secondary"
                        android:gravity="center"
                        android:text="🎓"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keep Student Features"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Budgeting, Savings Milestones, Subscriptions manager and Student Loans will remain fully accessible."
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Worker Functions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_green"
                        android:gravity="center"
                        android:text="💼"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unlock Worker Features"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Add Work Tasks tracking, Expense Claim filings, Payslip details, and Monthly Earnings stats."
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Important notice -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="This upgrade is instant and will customize your main dashboard to show both portfolios. You can manage your security PIN lock settings normally."
                        android:textColor="@color/qa_tertiary_icon"
                        android:textSize="11sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Upgrade CTA Button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmUpgrade"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Confirm Upgrade"
                android:textAllCaps="false"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="@color/hero_accent"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_signup_arrow"
                app:iconGravity="end"
                app:iconPadding="8dp"
                app:iconTint="@color/text_on_dark_primary" />

            <ProgressBar
                android:id="@+id/progressBarUpgrade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminateTint="@color/hero_accent" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
