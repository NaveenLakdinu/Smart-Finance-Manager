<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Transaction Icon Container -->
    <FrameLayout
        android:id="@+id/frameTransactionIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/icon_circle_blue">

        <TextView
            android:id="@+id/txtTransactionEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎬"
            android:textSize="20sp" />

    </FrameLayout>

    <!-- Details Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <!-- Transaction Name -->
        <TextView
            android:id="@+id/txtTransactionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Netflix Subscription"
            android:textColor="#1F2937"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Transaction Date -->
        <TextView
            android:id="@+id/txtTransactionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="10 Jun 2026"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Transaction Amount -->
    <TextView
        android:id="@+id/txtTransactionAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rs.1,490"
        android:textColor="#EF4444"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
