<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════ -->
    <!--   SCROLLABLE CONTENT AREA                 -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/budgetScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/budgetContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top Header Banner ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_budget_header"
                android:padding="20dp">

                <!-- Back button with translucent circle background -->
                <FrameLayout
                    android:id="@+id/btnBackContainer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/bg_back_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_back"
                        android:contentDescription="Back" />

                </FrameLayout>

                <!-- Greeting & Title Group -->
                <LinearLayout
                    android:id="@+id/layoutHeaderTitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="@id/btnBackContainer"
                    app:layout_constraintBottom_toBottomOf="@id/btnBackContainer"
                    app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/txtGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning, Dulani 👋"
                        android:textColor="#D8E4FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Student Budget Planner"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Subtitle text -->
                <TextView
                    android:id="@+id/txtSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Plan your semester budget wisely"
                    android:textColor="#BCE0FF"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/layoutHeaderTitles"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Cards Layout Container ── -->
            <LinearLayout
                android:id="@+id/layoutCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp"
                android:layout_marginTop="-24dp">

                <!-- Card 1: Income Details -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIncomeDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Icon & Section Header -->
                        <LinearLayout
                            android:id="@+id/layoutIncomeTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:id="@+id/layoutIncomeIcon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/icon_circle_blue">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="$"
                                    android:textColor="#1E60FF"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Income Details"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Input Field: Monthly Allowance -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:layout_marginBottom="6dp"
                            android:text="Monthly Allowance (Rs.)"
                            android:textColor="#5A6470"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/editMonthlyAllowance"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_budget_input"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="15000"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:inputType="numberDecimal"
                            android:backgroundTint="@null"/>

                        <!-- Input Field: Scholarship Amount -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="6dp"
                            android:text="Scholarship Amount (Rs.)"
                            android:textColor="#5A6470"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/editScholarshipAmount"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_budget_input"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="5000"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:inputType="numberDecimal"
                            android:backgroundTint="@null"/>

                        <!-- Input Field: Part-Time Income -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="6dp"
                            android:text="Part-Time Income (Rs.)"
                            android:textColor="#5A6470"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/editPartTimeIncome"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_budget_input"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="8000"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:inputType="numberDecimal"
                            android:backgroundTint="@null"/>

                        <!-- Segmented Duration Options -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:layout_marginBottom="8dp"
                            android:text="Semester Duration (Months)"
                            android:textColor="#5A6470"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="4">

                            <!-- Option 3M -->
                            <TextView
                                android:id="@+id/btnDuration3M"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_inactive"
                                android:gravity="center"
                                android:text="3M"
                                android:textColor="#5A6470"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <Space android:layout_width="8dp" android:layout_height="1dp" />

                            <!-- Option 4M -->
                            <TextView
                                android:id="@+id/btnDuration4M"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_inactive"
                                android:gravity="center"
                                android:text="4M"
                                android:textColor="#5A6470"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <Space android:layout_width="8dp" android:layout_height="1dp" />

                            <!-- Option 6M (Selected) -->
                            <TextView
                                android:id="@+id/btnDuration6M"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_active"
                                android:gravity="center"
                                android:text="6M"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <Space android:layout_width="8dp" android:layout_height="1dp" />

                            <!-- Option 12M -->
                            <TextView
                                android:id="@+id/btnDuration12M"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_inactive"
                                android:gravity="center"
                                android:text="12M"
                                android:textColor="#5A6470"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                        </LinearLayout>

                        <!-- Action Button: Calculate Budget -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalculateBudget"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="24dp"
                            android:text="Calculate Budget"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#1E60FF"
                            app:cornerRadius="27dp"
                            app:strokeWidth="0dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card 2: Semester status summary -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSemesterSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_circle_blue">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                app:tint="#1E60FF"
                                android:contentDescription="Calendar" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtSemesterDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Semester: Jun 2026 – Dec 2026"
                                android:textColor="#111827"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtSemesterStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="6 months remaining"
                                android:textColor="#6B7280"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════ -->
    <!--   BOTTOM NAVIGATION BAR                    -->
    <!-- ══════════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:itemIconTint="@color/budget_nav_color"
        app:itemTextColor="@color/budget_nav_color"
        app:menu="@menu/student_budget_bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
