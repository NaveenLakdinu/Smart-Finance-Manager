<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_login_form.xml — Redesigned to premium dark glassmorphic theme
  Consistent with dashboard aesthetics: deep navy, teal accents, glass cards.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:orientation="vertical">

    <!-- ── Hero header card ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.38"
        android:background="@drawable/bg_hero_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="@color/qa_teal_bg"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/hero_accent"
            app:strokeWidth="1.5dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="@color/hero_accent" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Welcome Back!"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Sign in to Smart Finance Manager"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ── Form card ───────────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.62"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Email field ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Email Address"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input_dark"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="email"
                    android:src="@drawable/ic_email"
                    app:tint="@color/text_on_dark_muted" />

                <EditText
                    android:id="@+id/usernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="you@example.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── Password field ──────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Password"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_input_dark"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="lock"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/text_on_dark_muted" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/passwordToggle"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="toggle password"
                    android:src="@drawable/ic_eye"
                    app:tint="@color/text_on_dark_muted" />
            </LinearLayout>

            <!-- ── Forgot password ─────────────────────────────────────── -->
            <TextView
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginBottom="28dp"
                android:padding="4dp"
                android:text="Forgot Password?"
                android:textColor="@color/hero_accent"
                android:textSize="13sp" />

            <!-- ── Login button ────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="28dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Sign In"
                android:textAllCaps="false"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="@color/hero_accent"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_login_arrow"
                app:iconGravity="end"
                app:iconPadding="8dp"
                app:iconTint="@color/text_on_dark_primary" />

            <!-- ── Divider ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="or continue with"
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider_dark" />
            </LinearLayout>

            <!-- ── Social icons ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/googleBtn"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Google"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_google" />

                <ImageView
                    android:id="@+id/facebookBtn"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Facebook"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_facebook" />

                <ImageView
                    android:id="@+id/appleBtn"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Apple"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_apple" />
            </LinearLayout>

            <!-- ── Sign up link ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don&#39;t have an account? "
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/signUpLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textColor="@color/hero_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="20dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>