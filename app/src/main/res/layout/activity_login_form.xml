<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/bannerImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/login_banner"
                android:contentDescription="Banner"
                android:clipToOutline="true"
                android:background="@drawable/banner_rounded_bottom" />
        </FrameLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="42dp"
                android:src="@drawable/logo"
                android:scaleType="fitStart"
                android:adjustViewBounds="true"
                android:layout_marginBottom="24dp" />

            <!-- Welcome Back -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back!"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login to manage your subscription"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <!-- Enter details -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your details below"
                android:textColor="#374151"
                android:textSize="14sp"
                android:layout_marginBottom="18dp" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_field_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_person"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="user" />

                <EditText
                    android:id="@+id/usernameInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Email Address"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:inputType="textEmailAddress"
                    android:background="@null"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_field_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_lock"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="lock" />

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Password"
                    android:textColorHint="#9CA3AF"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <ImageView
                    android:id="@+id/passwordToggle"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="show password" />
            </LinearLayout>

            <!-- Forget Password -->
            <TextView
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Forget Password?"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:layout_marginBottom="28dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="LOGIN"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/btn_login_black"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or continue with"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E5E7EB" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="28dp">

                <ImageView
                    android:id="@+id/googleBtn"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_google"
                    android:background="@drawable/social_btn_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Google"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/facebookBtn"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_facebook"
                    android:background="@drawable/social_btn_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Facebook"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/appleBtn"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_apple"
                    android:background="@drawable/social_btn_bg"
                    android:padding="12dp"
                    android:contentDescription="Apple"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <!-- Sign Up link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don&#39;t have an account? "
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/signUpLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textColor="#3B82F6"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>