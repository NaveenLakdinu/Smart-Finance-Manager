<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp">



        <!-- ── Header ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProfileLetter"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_profile_circle"
                android:gravity="center"
                android:text="P"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello! 👋"
                    android:textColor="#7A9CC0"
                    android:textSize="13sp" />

                <!-- Account Switcher -->
                <LinearLayout
                    android:id="@+id/btnSwitchAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="3dp">

                    <TextView
                        android:id="@+id/txtCurrentAccountName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Account"
                        android:textColor="#F0F6FF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="-90"
                        app:tint="#00D4AA" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/btnNotifications"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification"
                android:gravity="center"
                android:text="🔔"
                android:textSize="20sp" />

        </LinearLayout>

        <!-- ── Balance Hero Card ──────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#00000000"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_card"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CURRENT BALANCE"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"
                    android:letterSpacing="0.12" />

                <!-- Balance amount row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtAccountBalance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LKR 125,400.00"
                        android:textColor="#FFFFFF"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <!-- Positive change pill -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#0F3320"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="▲ 2.4%"
                        android:textColor="#4ADE80"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Account number -->
                <TextView
                    android:id="@+id/txtAccountNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="**** **** 4290"
                    android:textColor="#4A6A8A"
                    android:textSize="14sp" />

                <!-- Accent bar -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:background="#00D4AA" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Section Title ──────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="10dp"
                android:background="#00D4AA" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quick Actions"
                android:textColor="#F0F6FF"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── Action Grid ────────────────────────── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2">

            <!-- Transfer -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTransfer"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_blue"
                        android:gravity="center"
                        android:text="💸"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Transfer"
                        android:textColor="#F0F6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View android:layout_width="18dp" android:layout_height="2dp"
                        android:layout_marginTop="5dp" android:background="#38BDF8" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Statements -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatements"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_green"
                        android:gravity="center"
                        android:text="📊"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Statements"
                        android:textColor="#F0F6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View android:layout_width="18dp" android:layout_height="2dp"
                        android:layout_marginTop="5dp" android:background="#4ADE80" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Loan Manager -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLoanManager"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_orange"
                        android:gravity="center"
                        android:text="💰"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Loan Manager"
                        android:textColor="#F0F6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View android:layout_width="18dp" android:layout_height="2dp"
                        android:layout_marginTop="5dp" android:background="#F59E0B" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cards -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCards"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_dark"
                        android:gravity="center"
                        android:text="💳"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Cards"
                        android:textColor="#F0F6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View android:layout_width="18dp" android:layout_height="2dp"
                        android:layout_marginTop="5dp" android:background="#A78BFA" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Add Account -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAddAccount"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_function_icon_blue"
                        android:gravity="center"
                        android:text="➕"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Add Account"
                        android:textColor="#F0F6FF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <View android:layout_width="18dp" android:layout_height="2dp"
                        android:layout_marginTop="5dp" android:background="#38BDF8" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ══ Divider with label ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1A3050" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:text="ACCOUNT"
                android:textColor="#2A4A6A"
                android:textSize="10sp"
                android:letterSpacing="0.18" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1A3050" />

        </LinearLayout>

        <!-- ══ Creative Logout Button ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_logout_btn"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_power"
                android:layout_marginEnd="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textColor="#FF4466"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                app:backgroundTint="#00000000"
                app:cornerRadius="0dp"
                app:strokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="You will be signed out of all devices"
            android:textColor="#2A4A6A"
            android:textSize="11sp" />

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>