<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBackIncome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_notification"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Add Income"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Total Income Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record New Income"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTotalIncomeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Total: Rs 0.00"
                android:textColor="@color/forest_300"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/forest_700"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amount (LKR)"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etIncomeAmount"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g. 5000"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Source -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Income Source"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etIncomeSource"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g. Salary, Freelance"
                    android:inputType="textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Date"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvIncomeDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:drawableEnd="@drawable/ic_calendar"
                    android:drawableTint="@color/text_on_dark_muted"
                    android:gravity="center_vertical"
                    android:hint="Select Date"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveIncome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/hero_accent"
            android:text="Save Income"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:cornerRadius="14dp" />

        <!-- Recent Incomes Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Incomes"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerIncomes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
