<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP GRADIENT CARD
             40% Complete + progress bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/top_gradient_card"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="28dp">

            <!-- Back arrow + 40% Complete -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="Back"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40% Complete"
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Personal Details label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Details"
                android:textColor="#374151"
                android:textSize="13sp"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="34dp" />

            <!-- Progress Steps — 2 active, 3 inactive -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">

                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_active"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_active"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive" />
            </LinearLayout>
        </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:outlineProvider="none"

                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="36dp">

                    <!-- Page Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter Your Loan Details"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="28dp" />

                    <!-- GRAY FORM CARD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/form_card_bg"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="20dp"
                        android:layout_marginBottom="32dp">

                        <!-- ── LOAN AMOUNT ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loan Amount"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/input_field_bg_focused"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginBottom="18dp">

                            <EditText
                                android:id="@+id/etLoanAmount"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Enter total loan amount"
                                android:textColorHint="#9CA3AF"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:background="@null" />
                        </LinearLayout>

                        <!-- ── MONTHLY INSTALLMENT ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Installment"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/input_field_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginBottom="18dp">

                            <EditText
                                android:id="@+id/etMonthlyInstallment"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Enter monthly payment"
                                android:textColorHint="#9CA3AF"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:background="@null" />
                        </LinearLayout>

                        <!-- ── NUMBER OF MONTHLY ALREADY PAID ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Number of Monthly already paid"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/input_field_bg"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginBottom="18dp">

                            <EditText
                                android:id="@+id/etMonthsPaid"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:hint="Enter amount"
                                android:textColorHint="#9CA3AF"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:background="@null" />
                        </LinearLayout>

                        <!-- ── PAYMENT METHOD SPINNER ─ -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Payment Method"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <Spinner
                            android:id="@+id/spinnerPaymentMethod"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/spinner_bg"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:entries="@array/payment_methods"
                            android:prompt="@string/select_payment" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextLoan"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Next"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_next_green"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        app:backgroundTint="@null" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

    </LinearLayout>
</ScrollView>