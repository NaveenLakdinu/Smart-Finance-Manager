<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Gradient Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/top_gradient_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="28dp">

            <!-- Back + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_notification"
                    android:padding="10dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_on_dark_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="40% Complete"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Details"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="56dp" />

            <!-- Progress Steps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5">

                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_active"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_active"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive"
                    android:layout_marginEnd="5dp" />
                <View android:layout_width="0dp" android:layout_height="5dp"
                    android:layout_weight="1" android:background="@drawable/progress_inactive" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp">

            <com.google.android.material.card.MaterialCardView
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:outlineProvider="none"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/forest_700">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Page Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter Your Loan Details"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="24dp" />

                    <!-- Loan Amount -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan Amount"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/etLoanAmount"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="Enter total loan amount"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textSize="14sp" />

                    <!-- Monthly Installment -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Installment"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/etMonthlyInstallment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="Enter monthly payment"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textSize="14sp" />

                    <!-- Months Paid -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Number of Months Already Paid"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/etMonthsPaid"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="Enter amount"
                        android:inputType="number"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textSize="14sp" />

                    <!-- Payment Method -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Method"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp" />

                    <Spinner
                        android:id="@+id/spinnerPaymentMethod"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:entries="@array/payment_methods"
                        android:prompt="@string/select_payment" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- Next Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextLoan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/hero_accent"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:cornerRadius="14dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
