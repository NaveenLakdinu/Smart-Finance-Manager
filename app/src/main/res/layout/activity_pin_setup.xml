<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_pin_setup.xml
  Screen for setting up a new PIN for the first time.
  Design: Premium dark glassmorphic theme matching the dashboard.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/forest_900"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- ── Header Row ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnPinSetupBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_notification"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Set PIN Lock"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Lock icon hero ──────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="40dp"
            app:cardBackgroundColor="@color/forest_700"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="@color/hero_accent" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Create Your PIN"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Set a 4-digit PIN to quickly access\nyour Smart Finance Manager."
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="14sp" />

        <!-- ── PIN Dot Display ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:orientation="horizontal">

            <View android:id="@+id/pinDot1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pin_dot_empty" />

            <View android:id="@+id/pinDot2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pin_dot_empty" />

            <View android:id="@+id/pinDot3"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pin_dot_empty" />

            <View android:id="@+id/pinDot4"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/pin_dot_empty" />
        </LinearLayout>

        <!-- ── Status Label ────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvPinSetupStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Enter your new PIN"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="13sp" />

        <!-- ── Numpad ──────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            app:cardBackgroundColor="@color/forest_700"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:padding="20dp"
                android:useDefaultMargins="false">

                <!-- Row 1: 1 2 3 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="1"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn2"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="2"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn3"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="3"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <!-- Row 2: 4 5 6 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn4"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="4"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="5"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn6"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="6"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <!-- Row 3: 7 8 9 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn7"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="7"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn8"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="8"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn9"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="9"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <!-- Row 4: (empty) 0 (backspace) -->
                <Space
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn0"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="0"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackspace"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="⌫"
                    android:textColor="@color/forest_300"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/forest_700"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/forest_600"
                    app:strokeWidth="1dp" />

            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Skip / Skip link ────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvSkipPin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="Skip – use password login instead"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="13sp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
