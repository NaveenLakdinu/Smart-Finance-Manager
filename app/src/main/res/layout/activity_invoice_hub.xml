<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_notification"
            android:gravity="center"
            android:text="←"
            android:textColor="#F0F6FF"
            android:textSize="20sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="B2B Invoices"
            android:textColor="#F0F6FF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTotalOutstanding"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_below="@id/layoutHeader"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Corporate Receivables"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Total Outstanding"
                    android:textColor="#B9C7D9"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtTotalAmountDue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs. 1,420,500"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:background="@drawable/bg_calendar_circle"
                android:gravity="center"
                android:text="🧾"
                android:textSize="30sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardTotalOutstanding"
        android:layout_marginTop="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <View
            android:layout_width="4dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_teal_bar" />

        <TextView
            android:id="@+id/lblRecent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Invoices"
            android:textColor="#F0F6FF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutLabel"
        android:layout_above="@+id/dummyAnchor"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvInvoices"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:clipToPadding="false"/>
    </com.google.android.material.card.MaterialCardView>

    <View
        android:id="@+id/dummyAnchor"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_alignParentBottom="true"
        android:visibility="invisible" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddInvoice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        app:backgroundTint="#00D4AA"
        android:src="@android:drawable/ic_input_add"
        app:tint="#071A33"
        app:fabSize="normal"
        app:elevation="8dp"
        android:contentDescription="Create invoice trigger shortcut" />

</RelativeLayout>