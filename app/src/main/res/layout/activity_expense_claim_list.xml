<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notification"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_on_dark_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Claim History"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 results"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Summary Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtPendingTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rs 0" android:textColor="@color/pill_warning_text" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtPendingCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 claims" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Approved" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtApprovedTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rs 0" android:textColor="@color/pill_positive_text" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtApprovedCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 claims" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rejected" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtRejectedTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rs 0" android:textColor="@color/danger_text" android:textSize="13sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtRejectedCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0 claims" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tabAll" android:layout_width="wrap_content" android:layout_height="32dp"
                android:background="@drawable/bg_tab_active" android:gravity="center" android:paddingHorizontal="14dp"
                android:layout_marginEnd="6dp" android:text="All" android:textColor="@color/qa_tertiary_icon" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tabPending" android:layout_width="wrap_content" android:layout_height="32dp"
                android:background="@drawable/bg_tab_inactive" android:gravity="center" android:paddingHorizontal="14dp"
                android:layout_marginEnd="6dp" android:text="Pending" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp"/>
            <TextView android:id="@+id/tabApproved" android:layout_width="wrap_content" android:layout_height="32dp"
                android:background="@drawable/bg_tab_inactive" android:gravity="center" android:paddingHorizontal="14dp"
                android:layout_marginEnd="6dp" android:text="Approved" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp"/>
            <TextView android:id="@+id/tabRejected" android:layout_width="wrap_content" android:layout_height="32dp"
                android:background="@drawable/bg_tab_inactive" android:gravity="center" android:paddingHorizontal="14dp"
                android:text="Rejected" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Claims List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerClaims"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📋" android:textSize="48sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:text="No claims found"
            android:textColor="@color/text_on_dark_primary" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:text="Submit your first expense claim"
            android:textColor="@color/text_on_dark_muted" android:textSize="13sp"/>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewClaim"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/hero_accent"/>

</LinearLayout>
