<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    tools:context=".MainActivity">


    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_finance_banner"
        android:contentDescription="Background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/dim_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/bottomPanel"
        app:layout_constraintVertical_bias="0.18">

        <!-- ✅ CIRCULAR LOGO -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/antLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:contentDescription="Red Ants Logo"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_ant_logos"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="@color/text_on_dark_primary"
            app:strokeWidth="3dp" />

        <!-- Brand label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:letterSpacing="0.45"
            android:id="@+id/brandLabel"
            android:text="RED ANTS"
            android:textColor="@color/black"
            android:textSize="11sp" />

        <!-- Divider line -->
        <View
            android:id="@+id/dividerLine"
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="6dp"
            android:background="@color/forest_300" />

        <!-- Main Title -->
        <TextView
            android:id="@+id/financeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:letterSpacing="0.10"
            android:lineSpacingMultiplier="1.3"
            android:shadowColor="@color/forest_300"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="12"
            android:text="SMART FINANCIAL&#10;MANAGEMENT"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bottom_panel_bg"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="30dp"
        android:paddingBottom="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Subtitle -->
        <TextView
            android:id="@+id/loginText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Login to manage your subscription"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="14sp"
            android:letterSpacing="0.01"
            android:gravity="center" />

        <!-- LOGIN BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="14dp"
            android:text="Login"
            android:textAllCaps="false"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/btn_login_gradient"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:gravity="center"
            app:backgroundTint="@null"
            app:cornerRadius="27dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_login_arrow"
            app:iconGravity="end"
            app:iconTint="@color/forest_300"
            app:iconSize="18dp" />

        <!-- SIGN UP BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signUpButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Sign Up"
            android:textAllCaps="false"
            android:textColor="@color/forest_800"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/btn_signup_light"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:gravity="center"
            app:backgroundTint="@null"
            app:cornerRadius="27dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_signup_arrow"
            app:iconGravity="end"
            app:iconTint="@color/forest_600"
            app:iconSize="18dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>