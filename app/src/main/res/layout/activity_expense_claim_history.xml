<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_notification"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_on_dark_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claim History"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All your expense claims"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Hero Stats Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL CLAIMS"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/txtTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rs 0.00"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 claims"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="12sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Mini Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtPendingTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="Rs 0" android:textColor="@color/pill_warning_text" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtPendingCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Approved" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtApprovedTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="Rs 0" android:textColor="@color/pill_positive_text" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtApprovedCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rejected" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
                <TextView android:id="@+id/txtRejectedTotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="Rs 0" android:textColor="@color/danger_text" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:id="@+id/txtRejectedCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/text_on_dark_muted" android:textSize="10sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Filter Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabAll"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="6dp"
            android:text="All"
            android:textColor="@color/qa_tertiary_icon"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabPending"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="6dp"
            android:text="Pending"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabApproved"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="6dp"
            android:text="Approved"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tabRejected"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="Rejected"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Claims List Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Claims"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 results"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Claims RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerClaims"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋"
            android:textSize="56sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No Claims Found"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Submit your first expense claim\nto see it here"
            android:gravity="center"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
