<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    tools:context=".StudentProfileActivity">

    <!-- ══════════════════════════════════════════ -->
    <!--   SCROLLABLE CONTENT AREA                 -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/profileContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════ -->
            <!--   HERO HEADER: Avatar + Name + Stats      -->
            <!-- ══════════════════════════════════════════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutProfileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_card"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <!-- Decorative circle accent top-right -->
                <View
                    android:id="@+id/viewProfileCircleAccent"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="-30dp"
                    android:alpha="0.12"
                    android:background="@drawable/bg_profile_circle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Back Button -->
                <ImageButton
                    android:id="@+id/btnBackToHome"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back to Home"
                    app:tint="@color/text_on_dark_primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Avatar Circle -->
                <FrameLayout
                    android:id="@+id/frameProfileAvatar"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/btnBackToHome"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Outer white ring -->
                    <View
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_avatar_ring" />

                    <!-- Avatar background circle -->
                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_profile_circle">

                        <ImageView
                            android:id="@+id/imgProfileAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            android:contentDescription="Profile Avatar"
                            app:tint="@color/text_on_dark_primary" />

                    </FrameLayout>

                    <!-- Edit badge -->
                    <FrameLayout
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/icon_circle_blue"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✏"
                            android:textSize="10sp"
                            android:textColor="@color/text_on_dark_primary" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Name -->
                <EditText
                    android:id="@+id/txtProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Dulani Perera"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:background="@null"
                    android:inputType="textPersonName"
                    app:layout_constraintTop_toBottomOf="@id/frameProfileAvatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Email -->
                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="dulani@university.lk"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- University Info -->
                <TextView
                    android:id="@+id/txtProfileUniversity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="University of Colombo • Year 4"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileEmail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ── Stats Row ── -->
                <LinearLayout
                    android:id="@+id/layoutProfileStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileUniversity"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Goals Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatGoals"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        tools:ignore="RtlHardcoded">

                        <TextView
                            android:id="@+id/txtStatGoalsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Goals"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Saved Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatSaved"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatSavedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs.1.2L"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Saved"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Score Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatScore"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatScoreValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Score"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══════════════════════════════════════════ -->
            <!--   MENU ITEMS                               -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#F8FAFC">

                <!-- My Achievements Menu Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/glass_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏅"
                            android:textSize="22sp"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="My Achievements"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Financial Reports Menu Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuFinancialReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/glass_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="22sp"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Financial Reports"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Account Settings Menu Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuAccountSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/glass_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚙️"
                            android:textSize="22sp"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Account Settings"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Sign Out Button ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFF5F5"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/danger_text"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_power"
                            android:contentDescription="Sign Out"
                            app:tint="#EF4444" />

                        <TextView
                            android:id="@+id/txtSignOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="@color/danger_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── App Version Info ── -->
                <LinearLayout
                    android:id="@+id/layoutVersionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtAppVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Finance v1.0.0"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtAppTagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Final Year Project • 2026"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
