<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    tools:context=".StudentProfileActivity">

    <!-- ══════════════════════════════════════════ -->
    <!--   SCROLLABLE CONTENT AREA                 -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/profileContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════ -->
            <!--   HERO HEADER: Avatar + Name + Stats      -->
            <!-- ══════════════════════════════════════════ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutProfileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_card"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="52dp"
                android:paddingBottom="32dp">

                <!-- Decorative circle accent top-right -->
                <View
                    android:id="@+id/viewProfileCircleAccent"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="-30dp"
                    android:alpha="0.12"
                    android:background="@drawable/bg_profile_circle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Avatar Circle -->
                <FrameLayout
                    android:id="@+id/frameProfileAvatar"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Outer white ring -->
                    <View
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_avatar_ring" />

                    <!-- Avatar background circle -->
                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_profile_circle">

                        <ImageView
                            android:id="@+id/imgProfileAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            android:contentDescription="Profile Avatar"
                            app:tint="#FFFFFF" />

                    </FrameLayout>

                    <!-- Edit badge -->
                    <FrameLayout
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/icon_circle_blue"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✏"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Dulani Perera"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/frameProfileAvatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Email -->
                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="dulani@university.lk"
                    android:textColor="#BCE0FF"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- University Info -->
                <TextView
                    android:id="@+id/txtProfileUniversity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="University of Colombo • Year 4"
                    android:textColor="#BCE0FF"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileEmail"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ── Stats Row ── -->
                <LinearLayout
                    android:id="@+id/layoutProfileStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/txtProfileUniversity"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Goals Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatGoals"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        tools:ignore="RtlHardcoded">

                        <!-- Corner radius via ShapeAppearance not available simply, using bg_notification shape fallback -->
                        <TextView
                            android:id="@+id/txtStatGoalsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Goals"
                            android:textColor="#BCE0FF"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Saved Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatSaved"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatSavedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs.1.2L"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Saved"
                            android:textColor="#BCE0FF"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Score Stat -->
                    <LinearLayout
                        android:id="@+id/layoutStatScore"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#2A5EAA"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/txtStatScoreValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Score"
                            android:textColor="#BCE0FF"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══════════════════════════════════════════ -->
            <!--   CONTENT CARDS AREA                      -->
            <!-- ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutProfileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp"
                android:layout_marginTop="-8dp">

                <!-- ══════════════════════════════════════════ -->
                <!--   MY ACHIEVEMENTS CARD                    -->
                <!-- ══════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏅"
                                android:textSize="20sp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/txtAchievementsTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Achievements"
                                android:textColor="#111827"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Badges Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- Badge 1: Goal Setter (pink/red) -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeGoalSetter"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/icon_role_red"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🎯"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadgeGoalSetter"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Goal Setter"
                                    android:textColor="#9B1C1C"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                            <!-- Badge 2: 50% Saver (amber) -->
                            <LinearLayout
                                android:id="@+id/layoutBadge50Saver"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/icon_role_amber"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⭐"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadge50Saver"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="50% Saver"
                                    android:textColor="#92400E"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                            <!-- Badge 3: Budget Pro (green) -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeBudgetPro"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/icon_role_green"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📊"
                                    android:textSize="26sp"
                                    android:gravity="center" />

                                <TextView
                                    android:id="@+id/txtBadgeBudgetPro"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Budget Pro"
                                    android:textColor="#065F46"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════════ -->
                <!--   FINANCIAL REPORTS CARD (NEW)             -->
                <!-- ══════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFinancialReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📊"
                                android:textSize="22sp"
                                android:layout_marginEnd="10dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Financial Reports"
                                    android:textColor="#071A33"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Generate reports and track your financial goals."
                                    android:textColor="#6B7280"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Dropdown: Report Type -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Report Type"
                            android:textColor="#374151"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <Spinner
                            android:id="@+id/spinnerReportType"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_spinner"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />

                        <!-- Month Selector (Initially Visible) -->
                        <LinearLayout
                            android:id="@+id/layoutMonthSelector"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select Month"
                                android:textColor="#374151"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <Spinner
                                android:id="@+id/spinnerMonth"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_spinner"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp" />

                        </LinearLayout>

                        <!-- Custom Date Range Picker (Initially Hidden) -->
                        <LinearLayout
                            android:id="@+id/layoutDateRangePicker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp"
                            android:visibility="gone"
                            android:weightSum="2">

                            <!-- Start Date -->
                            <LinearLayout
                                android:id="@+id/btnStartDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_input_feild"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Start Date"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtStartDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Select Start Date"
                                    android:textColor="#9CA3AF"
                                    android:textSize="13sp"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <!-- End Date -->
                            <LinearLayout
                                android:id="@+id/btnEndDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_input_feild"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="End Date"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtEndDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Select End Date"
                                    android:textColor="#9CA3AF"
                                    android:textSize="13sp"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Generate Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGenerateReport"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="20dp"
                            android:text="Generate Report"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@null"
                            android:background="@drawable/bg_generate_button_gradient"
                            app:cornerRadius="14dp" />

                        <!-- Report Summary Preview Container (Initially Hidden) -->
                        <LinearLayout
                            android:id="@+id/layoutSummaryPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="16dp"
                            android:visibility="gone"
                            android:background="#F8FAFC"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Report Summary Preview"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="12dp" />

                            <!-- Progress indicator row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Custom Circular Progress (or standard Linear Progress) -->
                                <ProgressBar
                                    android:id="@+id/progressGoal"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="0dp"
                                    android:layout_height="12dp"
                                    android:layout_weight="1"
                                    android:progress="60"
                                    android:progressDrawable="@drawable/bg_progress_bar_custom" />

                                <TextView
                                    android:id="@+id/txtProgressPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="60%"
                                    android:textColor="#0F172A"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="10dp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="60% of financial goals completed"
                                android:textColor="#64748B"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="16dp" />

                            <!-- Metrics list -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <!-- Goals Created Row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="8dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Goals Created"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="3"
                                        android:textColor="#1E293B"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Goals Achieved Row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="8dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Goals Achieved"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1"
                                        android:textColor="#1E293B"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Current Savings Row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="8dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Current Savings"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Rs. 12,000"
                                        android:textColor="#1E293B"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Target Savings Row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="8dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Target Savings"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Rs. 20,000"
                                        android:textColor="#1E293B"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Remaining Amount Row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Remaining Amount"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Rs. 8,000"
                                        android:textColor="#EF4444"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                            </LinearLayout>

                            <!-- Buttons Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="16dp"
                                android:weightSum="2">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnViewDetailedReport"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="6dp"
                                    android:text="Detailed Report"
                                    android:textAllCaps="false"
                                    android:textSize="12sp"
                                    app:cornerRadius="12dp"
                                    app:strokeColor="#3B82F6"
                                    android:textColor="#2563EB" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDownloadPdfReport"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="Download PDF"
                                    android:textAllCaps="false"
                                    android:textSize="12sp"
                                    app:cornerRadius="12dp"
                                    app:strokeColor="#94A3B8"
                                    android:textColor="#475569" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── App Version Info ── -->
                <LinearLayout
                    android:id="@+id/layoutVersionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txtAppVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smart Finance v1.0.0"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/txtAppTagline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Final Year Project • 2026"
                        android:textColor="#D1D5DB"
                        android:textSize="11sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- ── Sign Out Button ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#FFF5F5"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FCA5A5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_power"
                            android:contentDescription="Sign Out"
                            app:tint="#EF4444" />

                        <TextView
                            android:id="@+id/txtSignOut"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Out"
                            android:textColor="#EF4444"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>
