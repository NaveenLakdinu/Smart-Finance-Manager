<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp">



        <!-- ── Header ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProfileLetter"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_profile_circle"
                android:gravity="center"
                android:text="W"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnNotifications"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification"
                android:gravity="center"
                android:text="🔔"
                android:textSize="20sp" />

            <FrameLayout
                android:id="@+id/btnSecurity"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_notification"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/forest_300" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/btnTopLogout"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_notification"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_power"
                    app:tint="@color/forest_300" />

            </FrameLayout>

        </LinearLayout>


        <!-- ── Earnings Hero Card ─────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_green"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MONTHLY EARNINGS"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/pill_positive_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="THIS MONTH"
                        android:textColor="@color/pill_positive_text"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Amount + icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtEarnings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rs 0.00"
                        android:textColor="@color/forest_100"
                        android:textSize="38sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_calendar_circle"
                        android:gravity="center"
                        android:text="💵"
                        android:textSize="30sp" />

                </LinearLayout>

                <!-- Payroll status -->
                <TextView
                    android:id="@+id/txtPayrollStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/hero_accent" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Savings Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSavingsWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700"
            app:strokeWidth="1dp"
            app:strokeColor="@color/forest_600"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_function_icon_green"
                    android:gravity="center"
                    android:text="💰"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT SAVINGS"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCurrentSavingsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Rs 0.00"
                        android:textColor="@color/forest_100"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnUpdateSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_primary_green"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="UPDATE"
                    android:textColor="@color/btn_primary_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Section Title ──────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:layout_marginEnd="10dp"
                android:background="@color/hero_accent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Worker Portal"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 modules"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ── Worker Cards Row 1 ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <!-- My Tasks -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWorkTasks"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_secondary"
                        android:gravity="center"
                        android:text="📝"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="My Tasks"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/qa_secondary_icon" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="14dp" android:layout_height="1dp" />

            <!-- Expense Claims -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardExpenseClaims"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_dark"
                        android:gravity="center"
                        android:text="🧾"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Expense Claims"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/qa_tertiary_icon" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Worker Cards Row 2 ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <!-- Payslips -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPayslips"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_orange"
                        android:gravity="center"
                        android:text="📄"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Payslips"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/pill_warning_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="14dp" android:layout_height="1dp" />

            <!-- Loan Manager -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLoanManager"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_orange"
                        android:gravity="center"
                        android:text="💰"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Loan Manager"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/pill_warning_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Worker Cards Row 3 ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <!-- Subscription Manager -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSubscriptionManager"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_secondary"
                        android:gravity="center"
                        android:text="📅"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Subscriptions"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/qa_secondary_icon" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="14dp" android:layout_height="1dp" />

            <!-- Saving Manager -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSavingManager"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_green"
                        android:gravity="center"
                        android:text="🏦"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Savings"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/pill_positive_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Worker Cards Row 4 ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <!-- Utility Manager -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUtilityManager"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="20dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_function_icon_orange"
                        android:gravity="center"
                        android:text="💡"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Utilities"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/pill_warning_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="14dp" android:layout_height="1dp" android:layout_weight="1" />

        </LinearLayout>

        <!-- ── Pending Tasks Section ──────────────── -->
        <LinearLayout
            android:id="@+id/recentActivitySection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/hero_accent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pending Tasks"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtViewAllTasks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all →"
                    android:textColor="@color/hero_accent"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerWorkerTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>