<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtCategoryIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_function_icon_blue"
            android:gravity="center"
            android:text="💡"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtBillName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electricity Bill"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBillDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Due June 20"
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#38BDF8" />

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#F87171" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>