<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/bBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_notification"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Back Button" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Invoice Details"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInvoiceStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_notification"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="PENDING"
                android:textColor="#FFB800"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtDetInvoiceNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#INV-9902"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDetBusinessWorkspace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Workspace: Loading..."
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/bg_calendar_circle"
                        android:gravity="center"
                        android:text="🏢"
                        android:textSize="24sp" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/divider_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BILLED TO:"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/txtDetClientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Global Logistics Ltd"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDetClientBRN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="BRN: BR-88392-X"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="13sp" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:stretchColumns="0">

                    <TableRow android:background="#0A1D37" android:padding="10dp">
                        <TextView android:text="Description" android:textStyle="bold" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp"/>
                        <TextView android:text="Qty" android:textStyle="bold" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp" android:gravity="end" android:layout_width="50dp"/>
                        <TextView android:text="Amount" android:textStyle="bold" android:textColor="@color/text_on_dark_secondary" android:textSize="12sp" android:gravity="end" android:layout_width="100dp"/>
                    </TableRow>

                    <TableRow android:padding="10dp">
                        <TextView android:id="@+id/txtDetItemName" android:text="Bulk Floral Event Supplies" android:textColor="@color/text_on_dark_primary" android:textSize="13sp"/>
                        <TextView android:id="@+id/txtDetQty" android:text="15" android:textColor="@color/text_on_dark_primary" android:textSize="13sp" android:gravity="end"/>
                        <TextView android:id="@+id/txtDetPrice" android:text="Rs. 45,000" android:textColor="@color/pill_positive_text" android:textSize="13sp" android:gravity="end"/>
                    </TableRow>
                </TableLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/divider_dark" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Receivable Amount"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtDetTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Rs. 45,000.00"
                        android:textColor="@color/hero_accent"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkPaid"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            app:backgroundTint="@color/pill_positive_text"
            android:text="MARK AS PAID &amp; RECONCILE"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendReminder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            app:backgroundTint="#2A1215"
            android:text="DELETE INVOICE RECORD"
            android:textColor="@color/danger_text"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#FF3333"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>