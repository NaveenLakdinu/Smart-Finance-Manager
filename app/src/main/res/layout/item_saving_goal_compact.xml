<?xml version="1.0" encoding="utf-8"?>
<!-- item_saving_goal_compact.xml: Compact card for SavingManagerActivity Dashboard -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/goal_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_goal_card"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Title + % -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvGoalName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/goal_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Goal Name" />

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/goal_mint"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="6dp"/>

        <!-- Target Amount -->
        <TextView
            android:id="@+id/tvTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target: Rs 0.00"
            android:textColor="@color/goal_text_mute"
            android:textSize="12.5sp"/>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- Progress bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/bg_progress_track">
            <View
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/goal_mint"/>
        </FrameLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
