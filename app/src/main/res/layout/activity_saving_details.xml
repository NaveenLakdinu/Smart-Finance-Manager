<?xml version="1.0" encoding="utf-8"?>
<!-- activity_saving_details.xml — mirrors GoalProgressScreen (Compose) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/goal_bg">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/goal_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="36dp"
        android:paddingBottom="32dp">

        <!-- ── Top Bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_goal_card"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/goal_text_mute"
                android:textSize="18sp"/>

            <View android:layout_width="14dp" android:layout_height="1dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAVINGS GOAL"
                    android:textColor="@color/goal_text_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal Details"
                    android:textColor="@color/goal_text"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="16dp"/>

        <!-- ── Hero Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Goal name + status badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvGoalTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal Name"
                        android:textColor="@color/goal_text"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGoalDates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Started -- — due --"
                        android:textColor="@color/goal_text_mute"
                        android:textSize="12.5sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="11dp"
                    android:paddingVertical="5dp"
                    android:text="● Active"
                    android:textColor="@color/goal_mint"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="20dp"/>

            <!-- Jar + Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Jar visual (Custom view) -->
                <com.example.smartfinancialmanagement.JarView
                    android:id="@+id/jarView"
                    android:layout_width="96dp"
                    android:layout_height="120dp"/>

                <View android:layout_width="20dp" android:layout_height="1dp"/>

                <!-- Stats -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Current saved row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="2dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Current saved"
                            android:textColor="@color/goal_text_mute"
                            android:textSize="12.5sp"/>
                        <TextView
                            android:id="@+id/tvCurrentSaved"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 0.00"
                            android:textColor="@color/goal_mint"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/goal_border"
                        android:layout_marginVertical="7dp"/>

                    <!-- Target amount row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="2dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Target amount"
                            android:textColor="@color/goal_text_mute"
                            android:textSize="12.5sp"/>
                        <TextView
                            android:id="@+id/tvTargetAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LKR 0.00"
                            android:textColor="@color/goal_text"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="18dp"/>

            <!-- Progress track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:background="@drawable/bg_pill">
                <View
                    android:id="@+id/progressDetail"
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="@color/goal_mint"/>
            </FrameLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- ── Stat Cards: Remaining + Monthly ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_goal_card"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REMAINING"
                    android:textColor="@color/goal_text_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>
                <View android:layout_width="1dp" android:layout_height="6dp"/>
                <TextView
                    android:id="@+id/tvRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LKR 0.00"
                    android:textColor="@color/goal_coral"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_goal_card"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY NEED"
                    android:textColor="@color/goal_text_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>
                <View android:layout_width="1dp" android:layout_height="6dp"/>
                <TextView
                    android:id="@+id/tvMonthlyNeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LKR 0.00"
                    android:textColor="@color/goal_gold"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- ── Dates Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_goal_card"
            android:orientation="horizontal"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START DATE"
                    android:textColor="@color/goal_text_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/tvStartDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/goal_text"
                    android:textSize="13.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TARGET DATE"
                    android:textColor="@color/goal_text_dim"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/tvTargetDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/goal_text"
                    android:textSize="13.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- ── Savings Log Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_goal_card"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Savings log"
                    android:textColor="@color/goal_text"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/btnAddSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_mint"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="＋ Add savings"
                    android:textColor="#FF04241B"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Add savings form (hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutAddForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_dark"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AMOUNT SAVED"
                    android:textColor="@color/goal_text_mute"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_goal_card"
                    android:hint="e.g. 40.00"
                    android:inputType="numberDecimal"
                    android:padding="10dp"
                    android:textColor="@color/goal_text"
                    android:textColorHint="@color/goal_text_dim"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"
                    android:text="Warning: This entry exceeds your target amount!"
                    android:textColor="@color/goal_gold"
                    android:textSize="11.5sp"/>

                <View android:layout_width="match_parent" android:layout_height="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTE (OPTIONAL)"
                    android:textColor="@color/goal_text_mute"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>

                <EditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_goal_card"
                    android:hint="e.g. Tuition allowance leftover"
                    android:padding="10dp"
                    android:singleLine="true"
                    android:textColor="@color/goal_text"
                    android:textColorHint="@color/goal_text_dim"
                    android:textSize="14sp"/>

                <View android:layout_width="match_parent" android:layout_height="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <TextView
                        android:id="@+id/btnCancelEntry"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_goal_card"
                        android:gravity="center"
                        android:text="Cancel"
                        android:textColor="@color/goal_text_mute"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/btnSaveEntry"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_btn_mint"
                        android:gravity="center"
                        android:text="Save entry"
                        android:textColor="#FF04241B"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="10dp"/>

            <TextView
                android:id="@+id/tvEmptyLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                android:gravity="center"
                android:text="No savings recorded yet — add your first one above."
                android:textColor="@color/goal_text_dim"
                android:textSize="13sp"
                android:paddingVertical="20dp"/>

            <!-- Log entries added programmatically -->
            <LinearLayout
                android:id="@+id/containerLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="16dp"/>

        <!-- ── Delete / Edit Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:weightSum="2">
            <TextView
                android:id="@+id/btnDeleteGoal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_btn_delete"
                android:gravity="center"
                android:text="Delete goal"
                android:textColor="@color/goal_coral"
                android:textSize="13.5sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/btnEditGoal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_btn_surface"
                android:gravity="center"
                android:text="Edit goal"
                android:textColor="@color/goal_text"
                android:textSize="13.5sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

<!-- ══════════════════════════════════════════════════ -->
<!-- CELEBRATION OVERLAY (full screen, above content)  -->
<!-- ══════════════════════════════════════════════════ -->
<FrameLayout
    android:id="@+id/celebrationOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:clickable="false"
    android:focusable="false">

    <!-- Confetti canvas — fills whole screen, passes through touches -->
    <com.example.smartfinancialmanagement.ConfettiView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"/>

    <!-- Celebration card — centered -->
    <LinearLayout
        android:id="@+id/celebrationBanner"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_celebration_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:elevation="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="44sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Goal Achieved!"
            android:textColor="@color/goal_mint"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCelebrationGoalName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text=""
            android:textColor="@color/goal_text"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="You crushed it! Keep saving! 🚀"
            android:textColor="@color/goal_text_mute"
            android:textSize="12.5sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"/>

    </LinearLayout>

</FrameLayout>

</FrameLayout>
