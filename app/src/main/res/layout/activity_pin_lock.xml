<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_pin_lock.xml
  Screen shown when the user opens the app and has a PIN set.
  Design: Premium dark glassmorphic theme matching the dashboard.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- ── App branding ───────────────────────────────────────────────── -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="36dp"
        android:layout_marginTop="56dp"
        android:adjustViewBounds="true"
        android:contentDescription="Logo"
        android:scaleType="fitCenter"
        android:src="@drawable/logo" />

    <!-- ── Lock icon ──────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/qa_teal_bg"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/hero_accent"
        app:strokeWidth="1.5dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock"
            app:tint="@color/hero_accent" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Welcome Back!"
        android:textColor="@color/text_on_dark_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Enter your PIN to continue"
        android:textColor="@color/text_on_dark_secondary"
        android:textSize="14sp" />

    <!-- ── PIN Dot Display ────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/pinDotsRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:orientation="horizontal">

        <View android:id="@+id/pinDot1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/pin_dot_empty" />

        <View android:id="@+id/pinDot2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/pin_dot_empty" />

        <View android:id="@+id/pinDot3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/pin_dot_empty" />

        <View android:id="@+id/pinDot4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/pin_dot_empty" />
    </LinearLayout>

    <!-- ── Error / hint label ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvPinLockStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text=""
        android:textColor="@color/danger_text"
        android:textSize="13sp" />

    <!-- ── Numpad ──────────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/glass_card_bg"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_card_border"
        app:strokeWidth="1dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="20dp"
            android:useDefaultMargins="false">

            <!-- Row 1 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="1"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="2"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="3"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <!-- Row 2 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="4"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="5"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="6"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <!-- Row 3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="7"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="8"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="9"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <!-- Row 4 -->
            <Space
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="0"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackspace"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="⌫"
                android:textColor="@color/hero_accent"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1dp" />

        </GridLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Forgot PIN link ────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvForgotPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:padding="8dp"
        android:text="Forgot PIN? Sign in with password"
        android:textColor="@color/hero_accent"
        android:textSize="13sp" />

</LinearLayout>
