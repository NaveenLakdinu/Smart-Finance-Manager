<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard">

    <!-- TOP GRADIENT — 100% Complete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_notification"
                android:contentDescription="Back"
                android:padding="9dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_marginEnd="10dp"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100% Complete"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saving Milestone Setup"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"
            android:layout_marginStart="48dp" />

        <!-- Progress — all 5 active -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" />
        </LinearLayout>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp">


            <!-- Page Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saving Plan"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tell us about your saving goals to help manage your finances better."
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

            <!-- GRAY FORM CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- ── SAVING GOAL NAME ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saving Goal Name"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/goalNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="e.g. New Car, House, Education"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp"
                        android:inputType="textCapSentences"
                        android:background="@null" />
                </LinearLayout>

                <!-- ── TARGET AMOUNT ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Amount"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs."
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/targetAmountInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="0.00"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp"
                        android:inputType="numberDecimal"
                        android:background="@null" />
                </LinearLayout>

                <!-- ── TARGET DATE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Date"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:id="@+id/targetDatePicker"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/targetDateText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Select goal deadline"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="calendar" />
                </LinearLayout>

                <!-- ── CURRENT SAVINGS ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Savings"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs."
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/currentSavingsInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="10,000.00"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp"
                        android:inputType="numberDecimal"
                        android:background="@null" />
                </LinearLayout>

                <!-- ── MONTHLY SAVING AMOUNT ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Saving Amount"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_dark"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs."
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp" />

                    <EditText
                        android:id="@+id/monthlyAmountInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="0.00"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="14sp"
                        android:inputType="numberDecimal"
                        android:background="@null" />
                </LinearLayout>

                <!-- ── SAVING FREQUENCY SPINNER ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saving Frequency"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/frequencySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:entries="@array/saving_frequencies" />

            </LinearLayout>

            <!-- PROGRESS PREVIEW CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Saving Progress Preview"
                    android:textColor="@color/hero_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <!-- Progress Bar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Progress"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp" />

                <ProgressBar
                    android:id="@+id/savingsProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/hero_accent"
                    android:progressBackgroundTint="@color/glass_card_border"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/progressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% of target reached"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- REGISTER BUTTON -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dash_bg_deep"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="36dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Next →"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/hero_accent"
            app:cornerRadius="16dp" />

    </LinearLayout>

</LinearLayout>