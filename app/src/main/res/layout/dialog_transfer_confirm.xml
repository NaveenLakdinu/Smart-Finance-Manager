<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/glass_card_bg"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm Transfer"
        android:textColor="@color/text_on_dark_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please review the transfer details below"
        android:textColor="@color/text_on_dark_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Amount (large, centered) -->
    <TextView
        android:id="@+id/txtDialogAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rs 0.00"
        android:textColor="@color/hero_accent"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        android:layout_marginBottom="16dp" />

    <!-- From row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="From"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/txtDialogFrom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Account Name"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Arrow indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↓"
            android:textColor="@color/hero_accent"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- To row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="13sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/txtDialogTo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Account Name"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark"
        android:layout_marginBottom="12dp" />

    <!-- Note section (hidden if empty) -->
    <TextView
        android:id="@+id/txtDialogNoteLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note"
        android:textColor="@color/text_on_dark_muted"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtDialogNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_on_dark_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

</LinearLayout>
