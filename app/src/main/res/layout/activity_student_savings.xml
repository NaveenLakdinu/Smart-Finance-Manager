<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".StudentSavingsActivity">

    <!-- ══════════════════════════════════════════ -->
    <!--   SCROLLABLE CONTENT AREA                 -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/savingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/savingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top Header Banner ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutSavingsHeader"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@drawable/bg_budget_header"
                android:padding="20dp">

                <!-- Back Button -->
                <FrameLayout
                    android:id="@+id/btnSavingsBackContainer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/bg_back_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:id="@+id/btnSavingsBack"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_back"
                        android:contentDescription="Back" />

                </FrameLayout>

                <!-- Header Title Group -->
                <LinearLayout
                    android:id="@+id/layoutSavingsHeaderTitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="@id/btnSavingsBackContainer"
                    app:layout_constraintBottom_toBottomOf="@id/btnSavingsBackContainer"
                    app:layout_constraintStart_toEndOf="@id/btnSavingsBackContainer"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/txtSavingsSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Achieve your financial goals faster."
                        android:textColor="#D8E4FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtSavingsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Student Savings Challenge"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Decorative circle accent (top-right) -->
                <View
                    android:id="@+id/viewHeaderCircle"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginEnd="-20dp"
                    android:alpha="0.15"
                    android:background="@drawable/bg_profile_circle"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Main Content Area (Cards, Tabs, etc.) ── -->
            <LinearLayout
                android:id="@+id/layoutSavingsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp"
                android:layout_marginTop="-20dp">

                <!-- ── Tab Selector: Savings Goals / Scholarship ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTabSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="4dp"
                        android:gravity="center_vertical">

                        <!-- Savings Goals Tab (Active) -->
                        <TextView
                            android:id="@+id/tabSavingsGoals"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_active"
                            android:gravity="center"
                            android:text="💰  Savings Goals"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Scholarship Tab (Inactive) -->
                        <TextView
                            android:id="@+id/tabScholarship"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_inactive"
                            android:gravity="center"
                            android:text="🎓  Scholarship"
                            android:textColor="#5A6470"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ── Create New Goal Button ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCreateGoal"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#F8FAFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#B0C6E8"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textColor="#1E60FF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/txtCreateGoalLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create New Goal"
                            android:textColor="#1E60FF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════════ -->
                <!--   SAVINGS GOAL CARD 1: Buy New Laptop     -->
                <!-- ══════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGoalLaptop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- ── Goal Header Row: Title + Circular Progress ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Title + Time -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtGoalLaptopTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Buy New Laptop"
                                    android:textColor="#111827"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⏱"
                                        android:textSize="12sp"
                                        android:layout_marginEnd="4dp" />

                                    <TextView
                                        android:id="@+id/txtGoalLaptopTime"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="2 months remaining"
                                        android:textColor="#6B7C93"
                                        android:textSize="12sp" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Circular Progress Indicator -->
                            <FrameLayout
                                android:id="@+id/frameGoalLaptopCircle"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_marginStart="12dp">

                                <ProgressBar
                                    android:id="@+id/circularProgressLaptop"
                                    style="@style/Widget.AppCompat.ProgressBar"
                                    android:layout_width="80dp"
                                    android:layout_height="80dp"
                                    android:max="100"
                                    android:progress="75"
                                    android:indeterminate="false"
                                    android:progressTint="#4CAF50"
                                    android:progressBackgroundTint="#E0E0E0" />

                                <TextView
                                    android:id="@+id/txtGoalLaptopPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="75%"
                                    android:textColor="#111827"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </FrameLayout>

                        </LinearLayout>

                        <!-- ── Target / Saved Row ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <!-- Target -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Target"
                                    android:textColor="#6B7C93"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/txtGoalLaptopTarget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Rs.120,000"
                                    android:textColor="#111827"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Saved (highlighted green bg) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/tag_green"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Saved"
                                    android:textColor="#16A34A"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/txtGoalLaptopSaved"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Rs.90,000"
                                    android:textColor="#16A34A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- ── Linear Progress Bar ── -->
                        <ProgressBar
                            android:id="@+id/linearProgressLaptop"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="14dp"
                            android:max="100"
                            android:progress="75"
                            android:progressTint="#4CAF50"
                            android:progressBackgroundTint="#E8F0FE" />

                        <!-- ── Min / Max Labels ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Rs.0"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/txtGoalLaptopMaxLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rs.120,000"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- ── Tip / Insight Box ── -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardGoalLaptopTip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="#EFF6FF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="To achieve this goal:"
                                    android:textColor="#374151"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtGoalLaptopMonthly"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Save Rs.15,000/month"
                                    android:textColor="#1E60FF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtGoalLaptopEstimate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Estimated: 2 months remaining"
                                    android:textColor="#6B7280"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════════ -->
                <!--   SAVINGS GOAL CARD 2: Semester Books     -->
                <!-- ══════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGoalBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- ── Goal Header Row: Title + Circular Progress ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Title + Time -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtGoalBooksTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Semester Books"
                                    android:textColor="#111827"
                                    android:textSize="17sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⏱"
                                        android:textSize="12sp"
                                        android:layout_marginEnd="4dp" />

                                    <TextView
                                        android:id="@+id/txtGoalBooksTime"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1 months remaining"
                                        android:textColor="#6B7C93"
                                        android:textSize="12sp" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Circular Progress Indicator (Blue for Semester Books) -->
                            <FrameLayout
                                android:id="@+id/frameGoalBooksCircle"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_marginStart="12dp">

                                <ProgressBar
                                    android:id="@+id/circularProgressBooks"
                                    style="@style/Widget.AppCompat.ProgressBar"
                                    android:layout_width="80dp"
                                    android:layout_height="80dp"
                                    android:max="100"
                                    android:progress="72"
                                    android:indeterminate="false"
                                    android:progressTint="#1E60FF"
                                    android:progressBackgroundTint="#E0E0E0" />

                                <TextView
                                    android:id="@+id/txtGoalBooksPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="72%"
                                    android:textColor="#111827"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </FrameLayout>

                        </LinearLayout>

                        <!-- ── Target / Saved Row ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <!-- Target -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Target"
                                    android:textColor="#6B7C93"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/txtGoalBooksTarget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Rs.25,000"
                                    android:textColor="#111827"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Saved (highlighted green bg) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/tag_green"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Saved"
                                    android:textColor="#16A34A"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/txtGoalBooksSaved"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Rs.18,000"
                                    android:textColor="#16A34A"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- ── Linear Progress Bar (Blue) ── -->
                        <ProgressBar
                            android:id="@+id/linearProgressBooks"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="14dp"
                            android:max="100"
                            android:progress="72"
                            android:progressTint="#1E60FF"
                            android:progressBackgroundTint="#E8F0FE" />

                        <!-- ── Min / Max Labels ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Rs.0"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/txtGoalBooksMaxLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rs.25,000"
                                android:textColor="#9CA3AF"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <!-- ── Tip / Insight Box ── -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardGoalBooksTip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="#EFF6FF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="To achieve this goal:"
                                    android:textColor="#374151"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/txtGoalBooksMonthly"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Save Rs.7,000/month"
                                    android:textColor="#1E60FF"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txtGoalBooksEstimate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Estimated: 1 months remaining"
                                    android:textColor="#6B7280"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════════ -->
                <!--   ACHIEVEMENTS SECTION                    -->
                <!-- ══════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- ── Section Header ── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏅"
                                android:textSize="22sp"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/txtAchievementsTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Achievements"
                                android:textColor="#111827"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- ── Achievement Badges Row ── -->
                        <LinearLayout
                            android:id="@+id/layoutAchievementBadges"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <!-- Badge 1: First Goal Created -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeFirstGoal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:layout_gravity="center">

                                    <View
                                        android:layout_width="64dp"
                                        android:layout_height="64dp"
                                        android:background="@drawable/icon_circle_red" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="🎯"
                                        android:textSize="28sp" />

                                </FrameLayout>

                                <TextView
                                    android:id="@+id/txtBadgeFirstGoalTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="First Goal Created"
                                    android:textColor="#374151"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Earned "
                                        android:textColor="#16A34A"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="✓"
                                        android:textColor="#16A34A"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Badge 2: 50% Progress -->
                            <LinearLayout
                                android:id="@+id/layoutBadge50Progress"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="@drawable/tag_amber">

                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:layout_gravity="center">

                                    <View
                                        android:layout_width="64dp"
                                        android:layout_height="64dp"
                                        android:background="@drawable/icon_circle_orange" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="⭐"
                                        android:textSize="28sp" />

                                </FrameLayout>

                                <TextView
                                    android:id="@+id/txtBadge50ProgressTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="50% Progress"
                                    android:textColor="#374151"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Earned "
                                        android:textColor="#16A34A"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="✓"
                                        android:textColor="#16A34A"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Badge 3: Goal Achieved (Locked/Pending) -->
                            <LinearLayout
                                android:id="@+id/layoutBadgeGoalAchieved"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:layout_gravity="center">

                                    <View
                                        android:layout_width="64dp"
                                        android:layout_height="64dp"
                                        android:background="@drawable/icon_circle_purple"
                                        android:alpha="0.4" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:text="🏆"
                                        android:textSize="28sp"
                                        android:alpha="0.5" />

                                </FrameLayout>

                                <TextView
                                    android:id="@+id/txtBadgeGoalAchievedTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Goal Achieved"
                                    android:textColor="#9CA3AF"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════ -->
    <!--   BOTTOM NAVIGATION BAR                    -->
    <!-- ══════════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:itemIconTint="@color/budget_nav_color"
        app:itemTextColor="@color/budget_nav_color"
        app:menu="@menu/student_bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
