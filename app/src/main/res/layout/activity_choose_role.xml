<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_choose_role.xml — Redesigned to premium dark glassmorphic theme.
  Step 2 of 5 in the registration flow. All IDs preserved for Java compatibility.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="36dp">

        <!-- ── Hero Header ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <!-- Top bar: back + step dots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Back"
                    android:padding="9dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_on_dark_primary" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <!-- Step dots -->
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_done" android:layout_marginEnd="5dp" />
                <View android:layout_width="22dp" android:layout_height="8dp"
                    android:background="@drawable/step_active" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" />
            </LinearLayout>

            <!-- Step badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_pill_accent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Step 2 of 5"
                android:textColor="@color/hero_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Choose Your Role"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We'll personalize your dashboard based on your financial profile."
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── Role Cards ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp">

            <!-- Student -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roleStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/qa_blue_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_school"
                            app:tint="@color/qa_blue_icon" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Budget, savings &amp; student loans"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/tag_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Budget"
                                android:textColor="@color/qa_blue_icon"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/tag_green"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Savings"
                                android:textColor="@color/qa_green_icon"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/radioStudent"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked"
                        android:contentDescription="Select Student"
                        app:tint="@color/hero_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Company Worker -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roleWorker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/qa_teal_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_work"
                            app:tint="@color/qa_teal_icon" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Company Worker"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Payslips, tasks &amp; loan tracker"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/tag_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Payslip"
                                android:textColor="@color/qa_blue_icon"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/tag_purple"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Tasks"
                                android:textColor="@color/qa_purple_icon"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/radioWorker"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked"
                        android:contentDescription="Select Worker"
                        app:tint="@color/hero_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Business Owner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roleBusiness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/qa_amber_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_business"
                            app:tint="@color/qa_amber_icon" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Business Owner"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Revenue, expenses &amp; invoices"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/tag_amber"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Revenue"
                                android:textColor="@color/qa_amber_icon"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/tag_green"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Invoices"
                                android:textColor="@color/qa_green_icon"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/radioBusinessOwner"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked"
                        android:contentDescription="Select Business Owner"
                        app:tint="@color/hero_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Multiple Account Holder -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roleMulti"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_card_border"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/qa_purple_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_group"
                            app:tint="@color/qa_purple_icon" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Multiple Accounts"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Manage multiple financial profiles"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/tag_purple"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Multi"
                                android:textColor="@color/qa_purple_icon"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/tag_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Advanced"
                                android:textColor="@color/qa_blue_icon"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/radioMulti"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_unchecked"
                        android:contentDescription="Select Multiple Accounts"
                        app:tint="@color/hero_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Continue Button ──────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/continueBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Continue"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="@color/hero_accent"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_signup_arrow"
                app:iconGravity="end"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>