<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_choose_role.xml — Premium dark glassmorphic theme.
  Step 2 of 5 in the registration flow. All IDs preserved for Java compatibility.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="36dp">

        <!-- ── Hero Header ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <!-- Top bar: back + step dots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_notification"
                    android:contentDescription="Back"
                    android:padding="9dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_on_dark_primary" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <!-- Step dots -->
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_done" android:layout_marginEnd="5dp" />
                <View android:layout_width="22dp" android:layout_height="8dp"
                    android:background="@drawable/step_active" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/step_inactive" />
            </LinearLayout>

            <!-- Step badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_pill_accent"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Step 2 of 5"
                android:textColor="@color/hero_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Choose Your Role"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We'll personalize your dashboard based on your financial profile."
                android:textColor="@color/text_on_dark_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── Role Cards ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- STUDENT ROLE CARD                                          -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/roleStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/forest_600"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Top row: icon + title + radio -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardBackgroundColor="@color/qa_secondary_bg"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_school"
                                app:tint="@color/qa_secondary_icon" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Student"
                                android:textColor="@color/text_on_dark_primary"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Budget, savings &amp; student loans"
                                android:textColor="@color/text_on_dark_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/radioStudent"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_radio_unchecked"
                            android:contentDescription="Select Student"
                            app:tint="@color/hero_accent" />
                    </LinearLayout>

                    <!-- Feature tags row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/tag_secondary"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Budget"
                            android:textColor="@color/qa_secondary_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/tag_green"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Savings"
                            android:textColor="@color/qa_green_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/tag_tertiary"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Loans"
                            android:textColor="@color/qa_tertiary_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/tag_amber"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="Subscriptions"
                            android:textColor="@color/qa_amber_icon"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Feature details -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_dark"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What you get:"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="  •  Monthly budget planner &amp; tracking&#10;  •  Savings goals with progress&#10;  •  Student loan EMI calculator&#10;  •  Subscription manager"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- COMPANY WORKER ROLE CARD                                   -->
            <!-- ═══════════════════════════════════════════════════════════ -->
