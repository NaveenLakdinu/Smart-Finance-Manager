<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/glass_card_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"> <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="System Notifications 🔔"
        android:textColor="@color/text_on_dark_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

        <Button
            android:id="@+id/btnDismissNotifications"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="@color/forest_800"
            android:text="Close"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutNotificationsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />
</LinearLayout>