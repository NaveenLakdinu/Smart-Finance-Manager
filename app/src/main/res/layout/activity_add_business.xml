<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_notification"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Register Business"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/forest_700"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUSINESS INFORMATION"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Business Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Business Workspace Name"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etBusinessName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g., Flower Delivery System"
                    android:inputType="textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Business Category -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Business Category / Industry"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etBusinessCategory"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g., Logistics, Retail, E-Commerce"
                    android:inputType="textCapWords"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Contact Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Corporate Contact Number"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etBusinessPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g., +94 77 123 4567"
                    android:inputType="phone"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Business Email Address"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etBusinessEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g., contact@workspace.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBusiness"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/hero_accent"
            android:text="Save Business"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:cornerRadius="14dp" />

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
