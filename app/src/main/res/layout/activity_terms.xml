<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111827">

    <!-- TOP GRADIENT CARD-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/top_gradient_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="28dp">

        <!-- Back + 60% Complete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60% Complete"
                android:textColor="#1D4ED8"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Details"
            android:textColor="#374151"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"
            android:layout_marginStart="34dp" />

        <!-- Progress — 3 active, 2 inactive -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">

            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active"
                android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active"
                android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active"
                android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_inactive"
                android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_inactive" />
        </LinearLayout>
    </LinearLayout>

    <!-- WHITE CONTENT CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-20dp"
        android:outlineProvider="none"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I agree the terms and conditions"
                android:textColor="#111827"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="16dp"
                android:lineSpacingMultiplier="1.3" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp" />

            <!-- SCROLLABLE T&C CONTENT -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp">

                    <!-- Last Updated -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last updated: January 01, 2025"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:layout_marginBottom="20dp" />

                    <!-- Section 1 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Acceptance of Terms"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="By accessing or using Red Ants Smart Financial Management application, you agree to be bound by these Terms and Conditions. If you do not agree to these terms, please do not use our services. We reserve the right to update these terms at any time without prior notice."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 2 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. User Account &amp; Registration"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You must provide accurate, complete, and current information during registration. You are responsible for maintaining the confidentiality of your account credentials. You must immediately notify us of any unauthorized use of your account. We reserve the right to terminate accounts that violate our policies."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 3 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. Financial Data &amp; Privacy"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All financial data you provide is encrypted and stored securely. We do not share your personal financial information with third parties without your explicit consent. Your data may be used to improve our services and provide personalized financial insights. You can request deletion of your data at any time."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 4 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4. Loan Management Services"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Red Ants provides loan tracking and management tools for informational purposes only. We are not a licensed financial institution or lender. The information provided does not constitute financial advice. Always consult a qualified financial advisor before making any financial decisions."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 5 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5. Subscription &amp; Payments"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Some features of Red Ants require a paid subscription. Subscription fees are billed in advance on a monthly or annual basis. All payments are non-refundable unless required by applicable law. We reserve the right to change subscription pricing with 30 days notice."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 6 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6. Prohibited Activities"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You agree not to misuse our platform in any way, including but not limited to: entering false financial information, attempting to hack or disrupt our services, using the app for illegal financial activities, or violating any applicable local or international laws."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 7 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7. Limitation of Liability"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Red Ants shall not be liable for any indirect, incidental, or consequential damages arising from your use of our application. We do not guarantee the accuracy of financial calculations or projections. Use of this application is at your own risk."
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="18dp" />

                    <!-- Section 8 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8. Contact Us"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="If you have any questions about these Terms and Conditions, please contact us at:\n\nEmail: support@redants.com\nPhone: +94 11 234 5678\nAddress: No. 42, Colombo 03, Sri Lanka"
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>
            </ScrollView>

            <!-- AGREE CHECKBOX + NEXT BUTTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp"
                android:elevation="8dp">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginBottom="14dp" />

                <!-- Agree Checkbox -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <CheckBox
                        android:id="@+id/agreeCheckbox"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:buttonTint="#22C55E"
                        android:checked="false" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="I have read and agree to the Terms and Conditions"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:layout_marginStart="10dp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <!-- NEXT BUTTON -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nextButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Next"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_next_green"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>