<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:orientation="vertical"
    android:padding="20dp"
    tools:ignore="TooManyViews">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notification"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/cd_navigate_back"
            app:tint="@color/text_on_dark_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/my_tasks"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnAdd"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_fab_yellow"
            android:padding="10dp"
            android:src="@drawable/ic_plus"
            android:contentDescription="@string/cd_add_task"
            app:tint="#000000" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/daily_assignments"
        android:textColor="@color/text_on_dark_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textAllCaps="true" />

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:id="@+id/tvStatTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_total_label"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="11sp"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:layout_marginHorizontal="6dp">
            <TextView
                android:id="@+id/tvStatActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/qa_blue_icon"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_active_label"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="11sp"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:layout_marginHorizontal="6dp">
            <TextView
                android:id="@+id/tvStatDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/pill_positive_text"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_done_label"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="11sp"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:layout_marginStart="6dp">
            <TextView
                android:id="@+id/tvStatOverdue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F87171"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_overdue_label"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="11sp"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

    <!-- Overall Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overall"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvOverallPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="@color/qa_yellow"
            android:textSize="14sp"
            android:textStyle="bold" />
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
        <ProgressBar
            android:id="@+id/overallProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="140dp"
            android:layout_height="6dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/qa_yellow"
            android:progressBackgroundTint="@color/divider_dark"
            android:scaleY="0.6" />
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/cd_search"
            app:tint="@color/text_on_dark_muted" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:maxWidth="300dp"
            android:background="@android:color/transparent"
            android:hint="@string/search_tasks"
            android:textColorHint="@color/text_on_dark_muted"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="14sp"
            android:layout_marginStart="10dp"
            android:inputType="text"
            android:autofillHints="searchQuery" />

        <ImageView
            android:id="@+id/btnClearSearch"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_close_circle"
            android:visibility="gone"
            android:contentDescription="@string/cd_clear_search"
            app:tint="@color/text_on_dark_muted" />
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/tag_yellow_active"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="@string/filter_all"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterHigh"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="@string/filter_high"
                android:textColor="@color/qa_blue_icon"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterMedium"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:text="@string/filter_medium"
                android:textColor="@color/pill_positive_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterLow"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/filter_low"
                android:textColor="@color/qa_purple_icon"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Tasks RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No tasks yet"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap + to add your first task"
            android:textColor="@color/text_on_dark_muted"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
