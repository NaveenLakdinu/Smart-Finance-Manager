<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_subscription.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         TOP GRADIENT SECTION
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/top_gradient_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="80% Complete"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Details"
            android:textColor="#374151"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"
            android:layout_marginStart="34dp" />

        <!-- Progress — 4 active, 1 inactive -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_active" android:layout_marginEnd="5dp" />
            <View android:layout_width="0dp" android:layout_height="5dp"
                android:layout_weight="1" android:background="@drawable/progress_inactive" />
        </LinearLayout>
    </LinearLayout>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         CONTENT
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I want to receive&#10;subscription updates"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="8dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose how you want to stay informed about your financial activity."
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

            <!-- ── OPTION 1: Email Notifications ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/option_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_circle_green"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_email"
                        android:contentDescription="email" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Notifications"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Receive updates directly to your email"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#22C55E"
                    android:checked="true" />
            </LinearLayout>

            <!-- ── OPTION 2: SMS Notifications ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/option_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_circle_blue"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_phone"
                        android:contentDescription="sms" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMS Notifications"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get instant alerts via text message"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkSms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#22C55E"
                    android:checked="false" />
            </LinearLayout>

            <!-- ── OPTION 3: Push Notifications ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/option_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_circle_orange"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_notification"
                        android:contentDescription="push" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Push Notifications"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Real-time alerts on your device"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkPush"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#22C55E"
                    android:checked="false" />
            </LinearLayout>

            <!-- ── OPTION 4: Monthly Report ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/option_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_circle_purple"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_email"
                        android:contentDescription="report" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Financial Report"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Summary of your loans and savings"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkReport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#22C55E"
                    android:checked="false" />
            </LinearLayout>

            <!-- ── OPTION 5: Promotional Offers ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/option_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/icon_circle_red"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_email"
                        android:contentDescription="promo" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promotional Offers"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Special deals and exclusive discounts"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/checkPromo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#22C55E"
                    android:checked="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
         BOTTOM NEXT BUTTON
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="36dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Next"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/btn_next_green"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            app:backgroundTint="@null" />

    </LinearLayout>

</LinearLayout>