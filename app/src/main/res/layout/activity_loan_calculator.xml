<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_notification"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Loan Calculator"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Live Result Hero Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/forest_700"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Payment"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtMonthlyPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Rs 0.00"
                    android:textColor="@color/forest_100"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Interest"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtTotalInterest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rs 0.00"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/forest_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Payable"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtTotalPayable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rs 0.00"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/forest_600" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eff. Rate"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtEffectiveRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="—"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Input Form Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Loan Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loan Type"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spLoanType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

                <!-- Interest Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interest Calculation Method"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp" />

                <RadioGroup
                    android:id="@+id/rgInterestType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rbReducingBalance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reducing Balance"
                        android:checked="true"
                        android:textColor="@color/text_on_dark_secondary"
                        android:buttonTint="@color/hero_accent"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbFlatRate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Flat Rate"
                        android:textColor="@color/text_on_dark_secondary"
                        android:buttonTint="@color/hero_accent"
                        android:textSize="13sp" />
                </RadioGroup>

                <!-- Flat Rate Warning -->
                <TextView
                    android:id="@+id/txtFlatRateNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@color/pill_warning_bg"
                    android:padding="10dp"
                    android:text="Flat rate loans have a significantly higher true cost. Check the Effective Rate above."
                    android:textColor="@color/pill_warning_text"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Principal Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Principal Amount (LKR)"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="e.g. 500000"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_on_dark_primary"
                    android:textColorHint="@color/text_on_dark_muted"
                    android:textSize="14sp" />

                <!-- Rate + Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Annual Rate (%)"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/etRate"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input_dark"
                            android:hint="e.g. 10.5"
                            android:inputType="numberDecimal"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@color/text_on_dark_primary"
                            android:textColorHint="@color/text_on_dark_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration (Months)"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/etDuration"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input_dark"
                            android:hint="e.g. 60"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@color/text_on_dark_primary"
                            android:textColorHint="@color/text_on_dark_muted"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Savings Affordability Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            android:id="@+id/affordabilityCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_700">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Can I Afford This?"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtAffordabilityLoading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Savings stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Savings"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtCurrentSavings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rs —"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Saving"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtMonthlySaving"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rs — / mo"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/forest_600"
                    android:layout_marginBottom="16dp" />

                <!-- Verdict container -->
                <LinearLayout
                    android:id="@+id/verdictContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Buffer"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtBuffer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Rs —"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verdict"
                            android:textColor="@color/text_on_dark_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtVerdict"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="—"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Down payment note -->
                <TextView
                    android:id="@+id/txtDownPaymentNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- No savings note -->
                <TextView
                    android:id="@+id/txtNoSavingsNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="No savings data found. Add a savings plan in the Savings module to enable affordability analysis."
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save as Loan Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAsLoan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/hero_accent"
            android:text="Save as Loan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:cornerRadius="14dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
