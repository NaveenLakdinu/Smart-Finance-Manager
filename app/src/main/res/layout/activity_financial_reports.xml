<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_notification"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_on_dark_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Financial Reports"
                android:textColor="@color/text_on_dark_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Form Card -->
        <com.google.android.material.card.MaterialCardView
            app:strokeColor="@color/forest_600"
            app:strokeWidth="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/forest_700"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate Reports"
                    android:textColor="@color/text_on_dark_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate reports and track your financial goals."
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />

                <!-- Report Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report Type"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="20dp" />

                <Spinner
                    android:id="@+id/spinnerReportType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

                <!-- Month Selector -->
                <LinearLayout
                    android:id="@+id/layoutMonthSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Month"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/spinnerMonth"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp" />

                </LinearLayout>

                <!-- Custom Date Range Picker -->
                <LinearLayout
                    android:id="@+id/layoutDateRangePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/btnStartDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start Date"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtStartDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Start Date"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnEndDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_input_dark"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End Date"
                            android:textColor="@color/text_on_dark_muted"
                            android:textSize="11sp" />

                        <!-- Financial Summary -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_input_feild"
                            android:padding="16dp"
                            android:layout_marginBottom="16dp">

                            <!-- Balance -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Current Balance"
                                    android:textStyle="bold"
                                    android:textColor="#374151" />
                                <TextView
                                    android:id="@+id/txtReportBalance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textStyle="bold"
                                    android:textColor="#374151" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#E5E7EB"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <!-- Income -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Income"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/txtReportIncome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <!-- Savings -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Savings"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/txtReportSavings"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <!-- Loans -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Loans"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/txtReportLoans"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <!-- Subscriptions -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="4dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Subscriptions"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/txtReportSubscriptions"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <!-- Utilities -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Total Utility Bills"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/txtReportUtilities"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LKR 0.00"
                                    android:textColor="#6B7280"
                                    android:textSize="13sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- 1. Loans Chart -->
                        <TextView
                            android:id="@+id/txtEndDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select End Date"
                            android:textColor="@color/text_on_dark_primary"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Generate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateReport"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/hero_accent"
                    android:text="Generate Report"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    app:cornerRadius="14dp" />

                <!-- Report Summary Preview Container -->
                <LinearLayout
                    android:id="@+id/layoutSummaryPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    android:background="@color/forest_800"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Report Summary Preview"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- 1. Loans Chart -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan Details"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartLoans"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 2. Subscriptions Chart -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subscriptions"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartSubscriptions"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 3. Utility Bills Chart -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Utility Bills"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chartUtilityBills"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 4. Saving Progress Chart -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saving Progress"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    <com.github.mikephil.charting.charts.HorizontalBarChart
                        android:id="@+id/chartSavings"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDownloadPdfReport"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Download PDF"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/text_on_dark_muted"
                            android:textColor="@color/text_on_dark_muted" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
