<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/surface_primary"
    tools:context=".AccountSettingsActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="@color/text_on_dark_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Settings"
            android:textColor="@color/text_on_dark_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/forest_700"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
        app:strokeColor="@color/forest_600"
        app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile Information"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="Enter your full name"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="16dp" />

                    <!-- Age -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditAge"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="Enter your age"
                        android:inputType="number"
                        android:layout_marginBottom="16dp" />

                    <!-- Mobile -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditMobile"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="Enter mobile number"
                        android:inputType="phone"
                        android:layout_marginBottom="16dp" />

                    <!-- University -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="University"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditUniversity"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="e.g. University of Colombo"
                        android:inputType="text"
                        android:layout_marginBottom="16dp" />

                    <!-- Course -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Course"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditCourse"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="e.g. BSc Computer Science"
                        android:inputType="text"
                        android:layout_marginBottom="16dp" />

                    <!-- Student ID -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student ID"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/etEditStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_on_dark_primary"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:hint="e.g. STU12345"
                        android:inputType="text"
                        android:layout_marginBottom="32dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_dark"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Preferences"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preferred Currency"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerCurrency"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security"
                        android:textColor="@color/text_on_dark_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update Password"
                        android:textColor="@color/text_on_dark_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="New Password (optional)"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:inputType="textPassword"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Confirm Password"
                        android:textColorHint="@color/text_on_dark_muted"
                        android:textColor="@color/text_on_dark_primary"
                        android:inputType="textPassword"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveSettings"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Save Changes"
                        android:textColor="@color/text_on_dark_primary"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/btn_primary"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
