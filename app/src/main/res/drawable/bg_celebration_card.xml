<?xml version="1.0" encoding="utf-8"?>
<!-- Celebration banner card background: dark surface with mint border and glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle glow layer -->
    <item
        android:left="4dp"
        android:right="4dp"
        android:top="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#4D2FE0AC" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <!-- Main card -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A2340" />
            <stroke android:width="2dp" android:color="#2FE0AC" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
