<?xml version="1.0" encoding="utf-8"?>
<!-- Glass card with subtle top-edge teal highlight border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#243A5A" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <!-- Inner fill -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#182840"
                android:endColor="#111E30"
                android:angle="160" />
            <corners android:radius="21dp" />
        </shape>
    </item>
</layer-list>
