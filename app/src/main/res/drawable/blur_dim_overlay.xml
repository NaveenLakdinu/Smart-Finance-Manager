<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/blur_dim_overlay.xml
     This creates a dark frosted-glass tint over the background image. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#AA1A1A2E"
        android:centerColor="#881A1A2E"
        android:endColor="#661A1A2E"/>
</shape>

    <!--
        ══════════════════════════════════════════════════
        TO ACHIEVE REAL BLUR IN JAVA/KOTLIN (MainActivity):
        ══════════════════════════════════════════════════

        Step 1 — Add dependency in build.gradle (app):
            implementation 'com.github.Dimezis:BlurView:version-2.0.3'
            (or use RenderScript / Glide blur transformation)

        Step 2 — Replace the bgImage + overlay with BlurView:

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:blurOverlayColor="#66203060" />

        Step 3 — In your Activity onCreate():

        BlurView blurView = findViewById(R.id.blurView);
        View decorView = getWindow().getDecorView();
        ViewGroup rootView = decorView.findViewById(android.R.id.content);
        Drawable windowBackground = decorView.getBackground();

        blurView.setupWith(rootView, new RenderScriptBlur(this))
                .setFrameClearDrawable(windowBackground)
                .setBlurRadius(12f);
        ══════════════════════════════════════════════════
    -->